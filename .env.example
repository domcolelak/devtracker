# COPY THIS FILE TO .env AND FILL IN REAL VALUES BEFORE RUNNING docker-compose

# ---- POSTGRESQL (SHARED DATABASE, SEPARATE TABLES PER SERVICE) ----
POSTGRES_DB=devtracker
POSTGRES_USER=devtracker
POSTGRES_PASSWORD=change-me-devtracker-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://devtracker:change-me-devtracker-password@postgres:5432/devtracker

# ---- REDIS (CELERY BROKER + RESULT BACKEND) ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- DJANGO CORE SERVICE ----
DJANGO_SECRET_KEY=change-me-django-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,core-django
DJANGO_PORT=8000

# ---- SHARED JWT SETTINGS (TOKENS ISSUED BY DJANGO, VALIDATED BY FASTAPI) ----
JWT_SIGNING_KEY=change-me-jwt-signing-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- FASTAPI SERVICE ----
FASTAPI_PORT=8001

# ---- FLASK REPORTS SERVICE ----
FLASK_PORT=5000
FLASK_SECRET_KEY=change-me-flask-secret-key

# ---- MOCK SMTP FOR CELERY EMAIL SUMMARY TASK ----
EMAIL_HOST=mock
EMAIL_FROM=devtracker@example.com

# ---- NGINX ----
NGINX_PORT=80
